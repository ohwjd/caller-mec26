            <changeDesc xml:id="cxgrmt9">
               <p xml:id="pfh3vg91">Fol. 29r, system 2, last minima, it looks like the scribe crossed through "1" and wrote an "n" above. Indicated with del-tag.</p>
            </changeDesc>
         </change>
         <change xml:id="cckkyrd" isodate="2025-06-03" n="2" resp="#projectstaff-17">
            <changeDesc xml:id="caavsx7">
               <p xml:id="phcwyku1">Fol. 29r, system 3, measure 2, last minima, it looks like the scribe first wrote "d" in the lower voice by mistake and crossed it through. Indicated with del-tag.</p>
            </changeDesc>
         </change>
         <change xml:id="chtnbgo1" isodate="2025-03-07" n="3" resp="#projectstaff-17">
            <changeDesc xml:id="cbiodiu2">
               <p xml:id="pmqneaz1">Fol. 29r, system 3, end of measure 3, only the upper part of the barline is drawn. Indicated with unclear-tag.</p>
            </changeDesc>
         </change>
